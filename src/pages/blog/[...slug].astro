---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Prose from "../../components/Prose.astro";
import { formatDate, isoDate, readingTime } from "../../utils";
import "katex/dist/katex.min.css";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate, updatedDate, tags, heroImage } = post.data;
const minutes = readingTime(post.body ?? "");
---

<BaseLayout title={title} description={description} image={heroImage?.src}>
  <article class="post">
    <header class="post-head">
      <a href="/blog" class="back link-slide">← Blog</a>
      <div class="meta">
        <time datetime={isoDate(pubDate)}>{formatDate(pubDate)}</time>
        <span class="sep">/</span>
        <span>{minutes}</span>
        {
          updatedDate && (
            <>
              <span class="sep">/</span>
              <span>updated {formatDate(updatedDate)}</span>
            </>
          )
        }
      </div>
      <h1>{title}</h1>
      <p class="dek">{description}</p>
      {
        tags.length > 0 && (
          <div class="tags">
            {tags.map((t) => (
              <span class="tag">{t}</span>
            ))}
          </div>
        )
      }
    </header>

    {
      heroImage && (
        <Image src={heroImage} alt="" class="hero" loading="eager" />
      )
    }

    <Prose>
      <Content />
    </Prose>
  </article>
</BaseLayout>

<style>
  .post {
    max-width: 44rem;
    margin: 0 auto;
  }
  .post-head {
    margin-bottom: 1.5rem;
  }
  .back {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--accent);
    text-decoration: none;
  }
  .meta {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted);
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-top: 1.5rem;
  }
  .sep {
    opacity: 0.5;
  }
  .post-head h1 {
    font-size: clamp(2rem, 5.5vw, 3rem);
    line-height: 1.08;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0.6rem 0 0;
  }
  .dek {
    font-size: 1.15rem;
    color: var(--muted);
    margin: 1rem 0 0;
    line-height: 1.5;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1.25rem;
  }
  .hero {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--border);
    margin: 1rem 0 2.5rem;
  }
</style>
