---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import portrait from "../assets/portrait.jpg";
import { SITE } from "../config";
import { PROJECTS } from "../data/projects";
import { PUBLICATIONS } from "../data/publications";
import { INTRO, NOW } from "../data/profile";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const latest = posts.slice(0, 2);
const featured = PROJECTS.filter((p) => p.featured).slice(0, 3);
const recent = PUBLICATIONS.slice(0, 3);
---

<BaseLayout wide>
  <section class="hero">
    <div class="hero-text">
      <p class="eyebrow">Institute of Science Tokyo · AI / interpretability</p>
      <h1 class="name">{SITE.name}</h1>
      <p class="lede">{INTRO}</p>
      <div class="cta">
        <a href="/research" class="btn btn-primary">Research</a>
        <a href="/projects" class="btn">Projects</a>
        <a href="/blog" class="btn">Blog</a>
        <a href={`mailto:${SITE.email}`} class="btn">Email</a>
      </div>
    </div>
    <figure class="hero-photo">
      <Image
        src={portrait}
        alt="Tyrone White standing on the bridge to Ukimidō, a temple on Lake Biwa."
        widths={[320, 480, 640]}
        sizes="(max-width: 720px) 60vw, 17rem"
        loading="eager"
      />
    </figure>
  </section>

  <section class="block">
    <header class="block-head">
      <h2>Now</h2>
      <span class="updated">Updated {NOW.updated}</span>
    </header>
    <ul class="now-list">
      {NOW.items.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  {
    recent.length > 0 && (
      <section class="block">
        <header class="block-head">
          <h2>Recent</h2>
          <a href="/research" class="link-slide see-all">
            All research →
          </a>
        </header>
        <ul class="recent-list">
          {recent.map((p) => (
            <li class="recent-item">
              <div class="recent-meta">
                <span class="recent-date">{p.date}</span>
                {p.status && <span class="status">{p.status}</span>}
              </div>
              <div>
                <p class="recent-title">{p.title}</p>
                <p class="recent-venue">{p.venue}</p>
              </div>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <section class="block">
    <header class="block-head">
      <h2>Selected projects</h2>
      <a href="/projects" class="link-slide see-all">All projects →</a>
    </header>
    <div class="grid">
      {
        featured.map((p) => (
          <ProjectCard
            title={p.title}
            description={p.description}
            tags={p.tags}
            links={p.links}
            year={p.year}
          />
        ))
      }
    </div>
  </section>

  {
    latest.length > 0 && (
      <section class="block">
        <header class="block-head">
          <h2>From the blog</h2>
          <a href="/blog" class="link-slide see-all">
            All posts →
          </a>
        </header>
        <div class="grid posts">
          {latest.map((post) => (
            <PostCard
              href={`/blog/${post.id}`}
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
            />
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>

<style>
  .hero {
    padding: 1rem 0 2.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3.5rem;
    display: grid;
    grid-template-columns: 1fr 17rem;
    gap: 2.5rem;
    align-items: center;
  }
  .hero-photo {
    margin: 0;
  }
  .hero-photo :global(img) {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--border);
    filter: saturate(0.95);
  }
  @media (max-width: 720px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }
    .hero-photo {
      max-width: 13rem;
      order: -1;
    }
  }
  .name {
    font-size: clamp(2.4rem, 6vw, 3.6rem);
    line-height: 1.05;
    font-weight: 600;
    letter-spacing: -0.015em;
    margin: 0.6rem 0 0;
  }
  .lede {
    color: var(--muted);
    font-size: 1.1rem;
    max-width: 60ch;
    margin: 1.3rem 0 0;
  }
  .cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 2rem 0 0;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--border-strong);
    padding: 0.6rem 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--ink);
    text-decoration: none;
  }
  .btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-2px);
  }
  .btn-primary {
    background: var(--accent);
    color: var(--accent-ink);
    border-color: var(--accent);
  }
  .btn-primary:hover {
    color: var(--accent-ink);
    opacity: 0.9;
  }

  .block {
    margin-top: 3.5rem;
  }
  .block-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .block-head h2 {
    font-size: 1rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    font-weight: 500;
    margin: 0;
  }
  .updated {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted);
  }
  .see-all {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--accent);
    text-decoration: none;
  }

  .now-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.7rem;
    max-width: 70ch;
  }
  .now-list li {
    position: relative;
    padding-left: 1.2rem;
    color: var(--ink);
  }
  .now-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 6px;
    height: 6px;
    background: var(--accent);
  }

  .recent-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1rem;
  }
  .recent-item {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 1rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 1rem;
  }
  .recent-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .recent-meta {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    align-items: flex-start;
  }
  .recent-date {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
  }
  .status {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 0.05rem 0.4rem;
  }
  .recent-title {
    font-weight: 600;
    margin: 0;
  }
  .recent-venue {
    color: var(--muted);
    font-size: 0.9rem;
    margin: 0.2rem 0 0;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .grid.posts {
    grid-template-columns: repeat(2, 1fr);
  }
  @media (max-width: 820px) {
    .grid,
    .grid.posts {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 560px) {
    .recent-item {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
    .recent-meta {
      flex-direction: row;
      align-items: center;
    }
  }
</style>
