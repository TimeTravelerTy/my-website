---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE } from "../config";

interface Props {
  title?: string;
  description?: string;
  /** absolute or site-relative OG image url */
  image?: string;
  /** widen the main column (used by the home hero) */
  wide?: boolean;
}

const {
  title,
  description = SITE.description,
  image,
  wide = false,
} = Astro.props;

const pageTitle = title ? `${title} · ${SITE.name}` : SITE.title;
const canonical = new URL(Astro.url.pathname, Astro.site ?? SITE.url).toString();
const ogImage = image ? new URL(image, Astro.site ?? SITE.url).toString() : undefined;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />

    <link rel="alternate" type="application/rss+xml" title={SITE.name} href="/rss.xml" />

    <!-- no-flash theme init: runs before paint -->
    <script is:inline>
      (function () {
        // Light is the default; we only switch to dark if the visitor has
        // explicitly chosen it before (persisted in localStorage).
        try {
          var stored = localStorage.getItem("theme");
          var theme = stored === "dark" ? "dark" : "light";
          document.documentElement.setAttribute("data-theme", theme);
        } catch (e) {}
      })();
    </script>

    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main" class:list={["main", { wide }]}>
      <slot />
    </main>
    <Footer />

    <style define:vars={{}}>
      .main {
        max-width: 64rem;
        margin: 0 auto;
        padding: 3.5rem 1.5rem 1rem;
        min-height: 60vh;
      }
      .main.wide {
        max-width: 72rem;
      }
      @media (max-width: 560px) {
        .main {
          padding: 2.25rem 1rem 1rem;
        }
      }
    </style>
  </body>
</html>
