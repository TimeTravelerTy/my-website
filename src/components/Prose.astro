---
// Typographic wrapper for rendered markdown/MDX. Styles are global but scoped
// under `.prose` so they don't leak into the rest of the UI.
---

<div class="prose">
  <slot />
</div>

<style is:global>
  .prose {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--ink);
  }
  .prose > * + * {
    margin-top: 1.15rem;
  }

  .prose h2 {
    font-size: 1.6rem;
    font-weight: 600;
    line-height: 1.2;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  .prose h3 {
    font-size: 1.2rem;
    font-weight: 600;
    margin-top: 2rem;
  }
  .prose h4 {
    font-size: 1.02rem;
    font-weight: 600;
    margin-top: 1.5rem;
    color: var(--muted);
    font-family: var(--font-mono);
  }

  .prose a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: opacity 150ms ease;
  }
  .prose a:hover {
    opacity: 0.7;
  }

  .prose strong {
    font-weight: 650;
  }

  .prose ul,
  .prose ol {
    padding-left: 1.4rem;
  }
  .prose li + li {
    margin-top: 0.4rem;
  }
  .prose ul {
    list-style: none;
  }
  .prose ul > li {
    position: relative;
  }
  .prose ul > li::before {
    content: "";
    position: absolute;
    left: -1.1rem;
    top: 0.7em;
    width: 6px;
    height: 6px;
    background: var(--accent);
  }
  .prose ol {
    list-style: decimal;
  }

  .prose blockquote {
    border-left: 2px solid var(--accent);
    padding: 0.4rem 0 0.4rem 1.1rem;
    color: var(--muted);
    background: var(--accent-soft);
  }
  .prose blockquote > * + * {
    margin-top: 0.6rem;
  }

  /* inline + block code */
  .prose code {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: var(--accent-soft);
    border: 1px solid var(--border);
    padding: 0.08em 0.35em;
  }
  .prose pre {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 1rem 1.15rem;
    overflow-x: auto;
    font-size: 0.85rem;
    line-height: 1.6;
  }
  .prose pre code {
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
  }

  /* tables */
  .prose table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    display: block;
    overflow-x: auto;
  }
  .prose thead {
    border-bottom: 2px solid var(--border-strong);
  }
  .prose th,
  .prose td {
    text-align: left;
    padding: 0.5rem 0.85rem;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }
  .prose th {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--muted);
    font-weight: 500;
  }
  .prose tbody tr:hover {
    background: var(--accent-soft);
  }

  /* a small table that should sit centered rather than stretch full width */
  .prose .table-narrow {
    display: flex;
    justify-content: center;
  }
  .prose .table-narrow table {
    display: table;
    width: auto;
    min-width: 20rem;
  }
  .prose .table-narrow th,
  .prose .table-narrow td {
    padding: 0.5rem 1.5rem;
  }

  .prose hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }

  /* footnotes (GFM) */
  .prose .footnotes {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    font-size: 0.9rem;
    color: var(--muted);
  }
  .prose .footnotes h2 {
    font-size: 0.78rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: none;
    padding: 0;
    margin: 0 0 0.75rem;
  }
  .prose sup a {
    text-decoration: none;
  }

  /* KaTeX: let horizontal scroll happen on small screens */
  .prose .katex-display {
    overflow-x: auto;
    overflow-y: hidden;
    padding: 0.25rem 0;
  }

  @media (max-width: 560px) {
    .prose {
      font-size: 1rem;
    }
    .prose h2 {
      font-size: 1.4rem;
    }
  }
</style>
